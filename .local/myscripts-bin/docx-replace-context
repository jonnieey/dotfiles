#!/usr/bin/env python3
"""
Context-Aware DOCX Placeholder Replacer

Features:
- JSON-based replacements
- Context-aware rules
- Multi-line support
- Handles paragraphs + tables
- Creates new file: original → original-auto.docx

Usage:
    python docx_replace.py -d input.docx -r replacements.json
"""

import os
import sys
import glob
import json
import argparse

try:
    from docx import Document
    from docx.enum.text import WD_BREAK
except ImportError:
    print("Install python-docx: pip install python-docx")
    sys.exit(1)


# -----------------------------
# LOAD REPLACEMENTS
# -----------------------------
def load_replacements(json_path):
    try:
        with open(json_path, "r") as f:
            data = json.load(f)

        normalized = []
        for item in data:
            if isinstance(item, list):
                normalized.append({
                    "old": item[0],
                    "new": item[1],
                    "context": None
                })
            elif isinstance(item, dict):
                normalized.append({
                    "old": item["old"],
                    "new": item["new"],
                    "context": item.get("context")
                })
            else:
                raise ValueError("Invalid replacement format")

        return normalized

    except Exception as e:
        print(f"Error loading JSON: {e}", file=sys.stderr)
        sys.exit(1)


# -----------------------------
# CONTEXT MATCHING
# -----------------------------
def context_matches(paragraphs, index, context, window=3):
    """
    Look around the paragraph (±window) for context text.
    """
    if context is None:
        return True

    start = max(0, index - window)
    end = min(len(paragraphs), index + window + 1)

    for i in range(start, end):
        if context in paragraphs[i].text:
            return True

    return False


# -----------------------------
# REPLACE IN PARAGRAPH
# -----------------------------
def replace_in_paragraphs(paragraphs, replacements):
    modified = False

    for i, paragraph in enumerate(paragraphs):
        original_text = paragraph.text
        new_text = original_text

        for rule in replacements:
            old = rule["old"]
            new = rule["new"]
            context = rule["context"]

            if old in new_text and context_matches(paragraphs, i, context):
                new_text = new_text.replace(old, new)

        if new_text != original_text:
            paragraph.clear()

            parts = new_text.split("\\n")
            run = paragraph.add_run(parts[0])

            for part in parts[1:]:
                run.add_break(WD_BREAK.LINE)
                run = paragraph.add_run(part)

            modified = True

    return modified


# -----------------------------
# PROCESS TABLES
# -----------------------------
def process_tables(doc, replacements):
    modified = False

    for table in doc.tables:
        for row in table.rows:
            for cell in row.cells:
                if replace_in_paragraphs(cell.paragraphs, replacements):
                    modified = True

    return modified


# -----------------------------
# PROCESS DOCUMENT
# -----------------------------
def process_doc(doc, replacements):
    modified = False

    if replace_in_paragraphs(doc.paragraphs, replacements):
        modified = True

    if process_tables(doc, replacements):
        modified = True

    return modified


# -----------------------------
# PROCESS FILE
# -----------------------------
def process_file(file_path, replacements):
    try:
        doc = Document(file_path)
    except Exception as e:
        print(f"Error opening {file_path}: {e}")
        return False

    base, ext = os.path.splitext(file_path)
    new_file = f"{base}-auto{ext}"

    modified = process_doc(doc, replacements)

    doc.save(new_file)

    if modified:
        print(f"Created (modified): {new_file}")
    else:
        print(f"Created (no changes): {new_file}")

    return modified


# -----------------------------
# MAIN
# -----------------------------
def main():
    parser = argparse.ArgumentParser(description="Context-aware DOCX replacer")
    parser.add_argument("-d", required=True, help="DOCX file or directory")
    parser.add_argument("-r", required=True, help="Replacement JSON file")

    args = parser.parse_args()

    target = args.d
    replacements = load_replacements(args.r)

    if not os.path.exists(target):
        print(f"Error: {target} does not exist")
        sys.exit(1)

    files = []

    if os.path.isdir(target):
        files = glob.glob(os.path.join(target, "*.docx"))
    else:
        files = [target]

    if not files:
        print("No DOCX files found")
        sys.exit(0)

    for f in files:
        process_file(f, replacements)


if __name__ == "__main__":
    main()
